{
  "expo": {
    "name": "TameerBook",
    "slug": "TameerBook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D1C18"
    },
    "scheme": "tameerbook",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.tameerbook.app",
      "adaptiveIcon": {
        "backgroundColor": "#F4F0E7",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "TameerBook receipts ke liye photos tak rasai chahta hai.",
          "cameraPermission": "TameerBook receipt ki tasveer lene ke liye camera istemal karta hai."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "dc89bb08-c2c7-4bdb-9a3b-c84ea4a0675a"
      }
    },
    "owner": "amir-9251"
  }
}
